---
/**
 * ContactSection.astro
 * Contact section with neumorphic social links.
 * Data consumed from locale JSON props.
 */
import { Icon } from "astro-icon/components";
import Antigravity from "./react/Antigravity/Antigravity.jsx";
import siteConfig from "../siteConfig.json";

interface SocialLink {
  platform: string;
  url: string;
  icon: string;
}

interface Props {
  section_label: string;
  heading: string;
  subheading: string;
  email_label: string;
}

const { section_label, heading, subheading, email_label } = Astro.props;

const { email, socials } = siteConfig as {
  email: string;
  socials: SocialLink[];
};

// Filter socials to grab only Github and Instagram to pair with Mail
const targetSocials = socials.filter((s) =>
  ["github", "instagram"].includes(s.icon),
);

const instagram = targetSocials.find((s) => s.icon === "instagram");
const github = targetSocials.find((s) => s.icon === "github");

const emailParts = email.split("@");
const emailUser = emailParts[0];
const emailDomain = emailParts[1] || "";
---

<section
  id="contact"
  class="section contact-section"
  aria-labelledby="contact-heading"
>
  <div class="antigravity-background">
    <Antigravity
      client:visible
      count={300}
      magnetRadius={6}
      ringRadius={7}
      waveSpeed={0.4}
      waveAmplitude={1}
      particleSize={1.5}
      lerpSpeed={0.05}
      color="#00E5FF"
      autoAnimate={true}
      particleVariance={1}
    />
  </div>
  <div class="container">
    <div class="contact-inner">
      <p class="section-label reveal">
        {section_label}
      </p>

      <h2 id="contact-heading" class="contact-heading reveal reveal-delay-1">
        {heading}
      </h2>

      <p class="contact-subheading reveal reveal-delay-2">
        {subheading}
      </p>

      <div class="contact-socials reveal reveal-delay-3">
        {
          instagram && (
            <a
              href={instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-social-btn"
              aria-label="Instagram"
              title="Instagram"
            >
              <Icon name="bx:bxl-instagram" class="contact-icon" />
            </a>
          )
        }

        <a
          class="contact-social-btn email-btn"
          aria-label={email_label}
          title={email_label}
          role="button"
          tabindex="0"
          onclick={`window.location.href='mailto:${emailUser}' + '@' + '${emailDomain}'`}
        >
          <Icon name="bx:bxs-envelope" class="contact-icon" />
        </a>

        {
          github && (
            <a
              href={github.url}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-social-btn"
              aria-label="GitHub"
              title="GitHub"
            >
              <Icon name="bx:bxl-github" class="contact-icon" />
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* ---------- Contact Section ---------- */

  #contact {
    position: relative;
    z-index: var(--z-base);
    background: var(--clr-bg);
    padding-bottom: var(--space-20);
    overflow: hidden;
  }

  .antigravity-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    opacity: 0.25;
  }

  .contact-section .container {
    position: relative;
    z-index: 2;
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--clr-text-primary);
    margin-bottom: var(--space-8);
  }

  .contact-subheading {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--clr-text-secondary);
    line-height: 1.7;
    max-width: 36rem;
    margin-bottom: var(--space-12);
  }

  .contact-socials {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .contact-icon {
    width: clamp(1.5rem, 5vw, 2rem);
    height: clamp(1.5rem, 5vw, 2rem);
  }

  /* ---------- Contact Social Buttons ---------- */

  .contact-social-btn {
    width: clamp(3.5rem, 12vw, 4.5rem);
    height: clamp(3.5rem, 12vw, 4.5rem);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--clr-bg);
    box-shadow: var(--neu-raised);
    border-radius: 50%;
    color: var(--clr-text-secondary);
    transition-property: color, box-shadow, transform;
    transition-duration: var(--duration-slow);
    transition-timing-function: var(--ease-out-expo);
  }

  @media (hover: hover) {
    .contact-social-btn:hover {
      color: var(--clr-accent-blue);
      box-shadow:
        12px 12px 24px var(--shadow-dark),
        -12px -12px 24px var(--shadow-light),
        0 0 24px var(--clr-accent-blue-glow);
      transform: translateY(-4px) scale(0.98);
    }
  }

  .contact-social-btn:active {
    box-shadow: var(--neu-inset);
    transform: translateY(0) scale(0.96);
  }
</style>
