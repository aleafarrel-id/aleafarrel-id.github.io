---
/**
 * ContactSection.astro
 * Contact section with neumorphic social links.
 * Data consumed from locale JSON props.
 */
import { Icon } from "astro-icon/components";
interface SocialLink {
  platform: string;
  url: string;
  icon: string;
}

interface FormData {
  name_label: string;
  name_placeholder: string;
  email_label: string;
  email_placeholder: string;
  message_label: string;
  message_placeholder: string;
  submit: string;
  success: string;
  error: string;
}

interface Props {
  section_label: string;
  heading: string;
  subheading: string;
  email_label: string;
  email: string;
  social_label: string;
  form: FormData;
  socials: SocialLink[];
}

const {
  section_label,
  heading,
  subheading,
  email_label,
  email,
  social_label,
  form,
  socials,
} = Astro.props;

// Filter socials to grab only Github and Instagram to pair with Mail
const targetSocials = socials.filter((s) =>
  ["github", "instagram"].includes(s.icon),
);

const instagram = targetSocials.find((s) => s.icon === "instagram");
const github = targetSocials.find((s) => s.icon === "github");
---

<section
  id="contact"
  class="section contact-section"
  aria-labelledby="contact-heading"
>
  <div class="container">
    <div class="contact-inner">
      <p class="section-label reveal">
        {section_label}
      </p>

      <h2 id="contact-heading" class="contact-heading reveal reveal-delay-1">
        {heading}
      </h2>

      <p class="contact-subheading reveal reveal-delay-2">
        {subheading}
      </p>

      <div class="contact-socials reveal reveal-delay-3">
        {
          instagram && (
            <a
              href={instagram.url}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-social-btn"
              aria-label="Instagram"
              title="Instagram"
            >
              <Icon name="bx:bxl-instagram" class="contact-icon" />
            </a>
          )
        }

        <a
          href={`mailto:${email}`}
          class="contact-social-btn"
          aria-label={`${email_label}: ${email}`}
          title={email}
        >
          <Icon name="bx:bxs-envelope" class="contact-icon" />
        </a>

        {
          github && (
            <a
              href={github.url}
              target="_blank"
              rel="noopener noreferrer"
              class="contact-social-btn"
              aria-label="GitHub"
              title="GitHub"
            >
              <Icon name="bx:bxl-github" class="contact-icon" />
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* ==========================================================
   CONTACT SECTION
   ========================================================== */

  #contact {
    position: relative;
    z-index: var(--z-base);
    background: var(--clr-bg);
    padding-bottom: var(--space-20);
  }

  .contact-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--clr-text-primary);
    margin-bottom: var(--space-8);
  }

  .contact-subheading {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--clr-text-secondary);
    line-height: 1.7;
    max-width: 36rem;
    margin-bottom: var(--space-12);
  }

  .contact-socials {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .contact-icon {
    width: var(--space-8);
    height: var(--space-8);
  }

  /* ==========================================================
   CONTACT SOCIAL BUTTONS
   ========================================================== */

  .contact-social-btn {
    width: 4.5rem;
    height: 4.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--clr-bg);
    box-shadow: var(--neu-raised);
    border-radius: 50%;
    color: var(--clr-text-secondary);
    transition: all var(--duration-slow) var(--ease-out-expo);
  }

  .contact-social-btn:hover {
    color: var(--clr-accent-blue);
    box-shadow:
      12px 12px 24px var(--shadow-dark),
      -12px -12px 24px var(--shadow-light),
      0 0 24px var(--clr-accent-blue-glow);
    transform: translateY(-4px);
  }

  .contact-social-btn:active {
    box-shadow: var(--neu-inset);
    transform: translateY(0);
  }
</style>
