---
/**
 * ExperienceSection.astro
 * Timeline-style experience section.
 * Data consumed from locale JSON props.
 */
interface ExperienceItem {
  id: number | string;
  name: string;
  title: string;
  description: string;
  image: string;
}

interface Props {
  section_label: string;
  heading: string;
  subheading: string;
  interaction_hint: string;
  center_label?: string;
  center_subtitle?: string;
  preview_label?: string;
  items: ExperienceItem[];
}

const { section_label, heading, subheading, interaction_hint, center_label, center_subtitle, preview_label, items } = Astro.props;

import CertificatesFlow from "./react/CertificatesFlow/CertificatesFlow.jsx";
---

<section
  id="experience"
  class="section py-32"
  aria-labelledby="experience-heading"
>
  {/* Decorative Background Elements */}
  <div class="experience-glow experience-glow-1"></div>
  <div class="experience-glow experience-glow-2"></div>

  <div class="container relative z-10">
    <div class="experience-header-wrapper">
      <p class="section-label reveal inline-block">{section_label}</p>
      <h2
        class="experience-heading reveal reveal-delay-1 font-black tracking-tighter"
        id="experience-heading"
      >
        {heading}
      </h2>
      <p class="experience-subheading reveal reveal-delay-2 mx-auto md:mx-0">{subheading}</p>
    </div>

    <div class="reveal reveal-delay-3">
      <div class="experience-flow-wrapper">
        <CertificatesFlow client:idle items={items} strings={{
          centerLabel: center_label,
          centerSubtitle: center_subtitle,
          previewLabel: preview_label
        }} />
      </div>
      {interaction_hint && (
        <p class="experience-interaction-hint">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 9c0-1.7 1.3-3 3-3h8c1.7 0 3 1.3 3 3v6c0 1.7-1.3 3-3 3H8c-1.7 0-3-1.3-3-3V9z"/><path d="M9 15h.01"/><path d="M12 15h.01"/><path d="M15 15h.01"/></svg>
          {interaction_hint}
        </p>
      )}
    </div>
  </div>
</section>

<style is:global>
  /* ==========================================================
   EXPERIENCE SECTION
   ========================================================== */

  #experience {
    position: relative;
    z-index: var(--z-base);
    background: var(--clr-bg);
    overflow: hidden; /* Contains the glowing orbs */
  }

  /* Decorative Glows */
  .experience-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.15;
    pointer-events: none;
    z-index: 0;
  }

  .experience-glow-1 {
    top: 10%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: var(--clr-accent-blue);
    animation: float 10s ease-in-out infinite alternate;
  }

  .experience-glow-2 {
    bottom: -10%;
    left: -10%;
    width: 500px;
    height: 500px;
    background: var(--clr-accent-orange);
    animation: float 12s ease-in-out infinite alternate-reverse;
  }

  @keyframes float {
    0% { transform: translateY(0) scale(1); }
    100% { transform: translateY(-40px) scale(1.05); }
  }

  .experience-heading {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 5vw, var(--text-6xl));
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--clr-text-primary);
    margin-bottom: var(--space-4);
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }

  .experience-subheading {
    font-size: var(--text-lg);
    color: var(--clr-text-secondary);
    max-width: 560px;
    line-height: 1.7;
    opacity: 0.9;
  }

  .experience-flow-wrapper {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--clr-bg-deep);
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
  }

  .experience-header-wrapper {
    text-align: center;
    margin-bottom: var(--space-16);
    position: relative;
    z-index: 10;
  }

  @media (min-width: 768px) {
    .experience-header-wrapper {
      text-align: left;
    }
  }

  .experience-interaction-hint {
    text-align: center;
    margin-top: var(--space-10);
    font-size: var(--text-sm);
    color: var(--clr-text-muted);
    font-family: var(--font-ui);
    letter-spacing: 0.025em;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
  }

  .experience-interaction-hint svg {
    opacity: 0.7;
    width: 16px;
    height: 16px;
  }
</style>
