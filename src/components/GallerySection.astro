---
import CircularGallery from "./react/CircularGallery/CircularGallery.jsx";

interface GalleryImage {
  src: string;
  title: string;
  description: string;
}

interface Props {
  section_label: string;
  heading: string;
  subheading: string;
  interaction_hint?: string;
  items: GalleryImage[];
}

const { section_label, heading, subheading, interaction_hint, items } =
  Astro.props;

const galleryItems = items.map((item) => ({
  image: item.src,
  text: item.title,
}));
---

<section id="gallery" class="section" aria-labelledby="gallery-heading">
  <div class="gallery-glow gallery-glow-1"></div>
  <div class="gallery-glow gallery-glow-2"></div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="gallery-header-wrapper">
      <p class="section-label reveal inline-block">{section_label}</p>
      <h2
        class="gallery-heading reveal reveal-delay-1 font-black tracking-tighter"
        id="gallery-heading"
      >
        {heading}
      </h2>
      <p class="gallery-subheading reveal reveal-delay-2 mx-auto md:mx-0">
        {subheading}
      </p>
    </div>

    <div class="reveal reveal-delay-3 mt-12">
      <div class="gallery-flow-wrapper">
        <CircularGallery
          client:idle
          items={galleryItems}
          bend={1.5}
          textColor="#ffffff"
          borderRadius={0.05}
          scrollEase={0.05}
          font="bold 14px 'Space Grotesk', sans-serif"
        />
      </div>
      {
        interaction_hint && (
          <p class="gallery-interaction-hint reveal reveal-delay-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <>
                <path d="M5 9c0-1.7 1.3-3 3-3h8c1.7 0 3 1.3 3 3v6c0 1.7-1.3 3-3 3H8c-1.7 0-3-1.3-3-3V9z" />
                <path d="M9 15h.01" />
                <path d="M12 15h.01" />
                <path d="M15 15h.01" />
              </>
            </svg>
            {interaction_hint}
          </p>
        )
      }
    </div>
  </div>
</section>

<style>
  @import "../styles/components/GallerySection.css";
</style>
