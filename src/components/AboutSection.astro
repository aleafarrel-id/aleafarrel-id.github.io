---
/**
 * AboutSection.astro
 * About section with skills chips.
 * Data consumed from locale JSON props.
 */
interface Props {
  section_label: string;
  heading: string;
  bio_1: string;
  bio_2: string;
  skills_label: string;
  skills: string[];
}

const { section_label, heading, bio_1, bio_2, skills_label, skills } =
  Astro.props;
---

<section id="about" class="section py-32" aria-labelledby="about-heading">
  <div class="container">
    <div class="about-grid">
      <!-- Text Column -->
      <div>
        <p class="section-label reveal tracking-widest">{section_label}</p>
        <h2
          class="about-heading reveal reveal-delay-1 font-black tracking-tighter"
          id="about-heading"
        >
          {heading}
        </h2>
        <p class="about-bio reveal reveal-delay-2">{bio_1}</p>
        <p class="about-bio reveal reveal-delay-3">{bio_2}</p>
      </div>

      <!-- Skills Column -->
      <div class="reveal reveal-delay-2">
        <p class="section-label" style="margin-bottom:var(--space-6);">
          {skills_label}
        </p>
        <div class="skills-grid">
          {
            skills.map((skill, i) => (
              <div class={`skill-chip reveal reveal-delay-${(i % 4) + 1}`}>
                {skill}
              </div>
            ))
          }
        </div>

        <!-- Decorative neumorphic card -->
        <div
          class="neu-raised-lg reveal reveal-delay-3"
          style="margin-top:var(--space-8);padding:var(--space-6);text-align:center;"
          aria-hidden="true"
        >
          <div
            style="font-family:var(--font-display);font-size:var(--text-5xl);font-weight:800;letter-spacing:-0.03em;color:var(--clr-text-primary);line-height:1;"
          >
            3+
          </div>
          <div
            style="font-family:var(--font-ui);font-size:var(--text-sm);color:var(--clr-text-muted);margin-top:var(--space-2);"
          >
            Years of Experience
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
/* ==========================================================
   ABOUT SECTION
   ========================================================== */

#about {
  position: relative;
  z-index: var(--z-base);
  background: var(--clr-bg);
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-16);
  align-items: center;
}

@media (min-width: 1024px) {
  .about-grid {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-24);
  }
}

.about-heading {
  font-family: var(--font-display);
  font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--clr-text-primary);
  margin-bottom: var(--space-6);
}

.about-bio {
  color: var(--clr-text-secondary);
  line-height: 1.8;
  margin-bottom: var(--space-4);
}

.skills-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3);
  margin-top: var(--space-8);
}

.skill-chip {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  font-weight: 500;
  padding: var(--space-3) var(--space-4);
  background: var(--clr-bg);
  box-shadow: var(--neu-raised-sm);
  border-radius: var(--radius-md);
  color: var(--clr-text-secondary);
  text-align: center;
  transition: all var(--duration-base) var(--ease-out-expo);
}

.skill-chip:hover {
  box-shadow: var(--neu-raised);
  color: var(--clr-accent-blue);
  transform: translateY(-2px);
}

</style>
