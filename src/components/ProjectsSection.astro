---
/**
 * ProjectsSection.astro
 * 3D Neumorphic project cards with tilt effect.
 * Data consumed from locale JSON props.
 */
interface ProjectItem {
  id: string | number;
  name: string;
  description: string;
  tags: string[];
  image: string;
  link?: string;
  playStoreUrl?: string;
  category: string;
}

interface Props {
  section_label: string;
  heading: string;
  subheading: string;
  view_project: string;
  items: ProjectItem[];
}

const { section_label, heading, subheading, view_project, items } = Astro.props;

import ProjectsScrollStack from "./react/ScrollStack/ProjectsScrollStack.jsx";
---

<section id="projects" class="section py-32" aria-labelledby="projects-heading">
  <div class="container">
    <p class="section-label reveal">{section_label}</p>
    <h2
      class="projects-heading reveal reveal-delay-1 font-black tracking-tighter"
      id="projects-heading"
    >
      {heading}
    </h2>
    <p class="projects-subheading reveal reveal-delay-2">{subheading}</p>

    <ProjectsScrollStack
      client:visible
      items={items}
      view_project={view_project}
    />
  </div>
</section>

<style is:global>
  /* ==========================================================
   PROJECTS SECTION
   ========================================================== */

  #projects {
    position: relative;
    z-index: var(--z-base);
    background: var(--clr-bg);
  }

  .projects-heading {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--clr-text-primary);
    margin-bottom: var(--space-4);
  }

  .projects-subheading {
    font-size: var(--text-lg);
    color: var(--clr-text-secondary);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: var(--space-16);
  }
</style>
