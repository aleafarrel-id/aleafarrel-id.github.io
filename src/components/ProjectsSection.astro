---
interface ProjectItem {
  id: string | number;
  name: string;
  description: string;
  tags: string[];
  image: string;
  link?: string;
  playStoreUrl?: string;
  category: string;
}

interface Props {
  section_label: string;
  heading: string;
  subheading: string;
  view_project: string;
  github_cta?: string;
  github_button?: string;
  items: ProjectItem[];
}

const {
  section_label,
  heading,
  subheading,
  view_project,
  github_cta,
  github_button,
  items,
} = Astro.props;

import ProjectsScrollStack from "./react/ScrollStack/ProjectsScrollStack.jsx";
---

<section id="projects" class="section" aria-labelledby="projects-heading">
  <div class="projects-glow projects-glow-1"></div>
  <div class="projects-glow projects-glow-2"></div>
  <div class="projects-glow projects-glow-3"></div>
  <div class="projects-glow projects-glow-4"></div>
  <div class="projects-glow projects-glow-cta"></div>
  <div class="projects-grid-bg"></div>

  <div class="container relative z-10">
    <p class="section-label reveal">{section_label}</p>
    <h2
      class="projects-heading reveal reveal-delay-1 font-black tracking-tighter"
      id="projects-heading"
    >
      {heading}
    </h2>
    <p class="projects-subheading reveal reveal-delay-2">{subheading}</p>

    <ProjectsScrollStack
      client:visible
      items={items}
      view_project={view_project}
    />

    {
      github_cta && github_button && (
        <div class="projects-github-cta-container reveal reveal-delay-3">
          <div class="projects-github-cta">
            <div class="cta-grid-bg" />

            <div class="cta-content relative z-10">
              <div class="cta-icon-wrapper">
                <svg
                  stroke="currentColor"
                  fill="none"
                  stroke-width="1.5"
                  viewBox="0 0 24 24"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                </svg>
              </div>

              <h3 class="github-cta-text font-display">{github_cta}</h3>

              <a
                href="https://github.com/aleafarrel-id"
                target="_blank"
                rel="noopener noreferrer"
                class="github-cta-btn"
              >
                <span>{github_button}</span>
                <svg
                  stroke="currentColor"
                  fill="none"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <line x1="5" y1="12" x2="19" y2="12" />
                  <polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  @import "../styles/components/ProjectsSection.css";
</style>
