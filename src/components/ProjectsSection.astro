---
/**
 * ProjectsSection.astro
 * 3D Neumorphic project cards with tilt effect.
 * Data consumed from locale JSON props.
 */
interface ProjectItem {
  id: string | number;
  name: string;
  description: string;
  tags: string[];
  image: string;
  link?: string;
  playStoreUrl?: string;
  category: string;
}

interface Props {
  section_label: string;
  heading: string;
  subheading: string;
  view_project: string;
  items: ProjectItem[];
}

const { section_label, heading, subheading, view_project, items } = Astro.props;

import ProjectsScrollStack from "./react/ScrollStack/ProjectsScrollStack.jsx";
---

<section id="projects" class="section" aria-labelledby="projects-heading">
  <!-- ---------- Decorative Background Elements ---------- -->
  <div class="projects-glow projects-glow-1"></div>
  <div class="projects-glow projects-glow-2"></div>
  <div class="projects-grid-bg"></div>

  <div class="container relative z-10">
    <p class="section-label reveal">{section_label}</p>
    <h2
      class="projects-heading reveal reveal-delay-1 font-black tracking-tighter"
      id="projects-heading"
    >
      {heading}
    </h2>
    <p class="projects-subheading reveal reveal-delay-2">{subheading}</p>

    <ProjectsScrollStack
      client:visible
      items={items}
      view_project={view_project}
    />
  </div>
</section>

<style is:global>
  /* ---------- Projects Section ---------- */

  #projects {
    position: relative;
    z-index: var(--z-base);
    background: var(--clr-bg);
    overflow: hidden;
  }

  /* ---------- Decorative Glows ---------- */
  .projects-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
  }

  .projects-glow-1 {
    top: 5%;
    left: 20%;
    width: 600px;
    height: 600px;
    background: var(--clr-glow-1);
    animation: float-projects 14s ease-in-out infinite alternate;
  }

  .projects-glow-2 {
    bottom: 10%;
    right: 5%;
    width: 500px;
    height: 500px;
    background: var(--clr-glow-2);
    animation: float-projects 18s ease-in-out infinite alternate-reverse;
  }

  @keyframes float-projects {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, -40px) scale(1.05); }
    100% { transform: translate(-20px, 20px) scale(0.95); }
  }

  /* ---------- Grid Texture Background ---------- */
  .projects-grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.15;
    background-image: 
      linear-gradient(to right, color-mix(in srgb, var(--clr-text-primary) 10%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--clr-text-primary) 10%, transparent) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(circle at center, black 20%, transparent 80%);
    -webkit-mask-image: radial-gradient(circle at center, black 20%, transparent 80%);
  }

  .projects-heading {
    font-family: var(--font-display);
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--clr-text-primary);
    margin-bottom: var(--space-4);
  }

  .projects-subheading {
    font-size: var(--text-lg);
    color: var(--clr-text-secondary);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: var(--space-8);
  }

  @media (min-width: 768px) {
    .projects-subheading {
      margin-bottom: var(--space-16);
    }
  }
</style>
