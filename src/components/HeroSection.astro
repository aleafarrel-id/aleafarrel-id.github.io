---
import { Icon } from "astro-icon/components";
interface Props {
  greeting: string;
  name: string;
  title: string;
  subtitle: string;
  cta_primary: string;
  cta_secondary: string;
  scroll_hint: string;
  projects_anchor: string;
  contact_anchor: string;
}

const {
  greeting,
  name,
  title,
  subtitle,
  cta_primary,
  cta_secondary,
  scroll_hint,
  projects_anchor,
  contact_anchor,
} = Astro.props;
---

<section id="hero" aria-label="Hero">
  <div class="hero-fade-overlay" id="hero-fade-overlay"></div>
  <div class="hero-content" id="hero-content-wrapper">
    <p class="hero-greeting" id="hero-greeting">{greeting}</p>
    <h1 class="hero-name" id="hero-name">{name}</h1>
    <p class="hero-title" id="hero-title">{title}</p>
    <p class="hero-subtitle" id="hero-subtitle">{subtitle}</p>
    <div class="hero-ctas" id="hero-ctas">
      <a href={projects_anchor} class="btn-primary" id="hero-cta-primary">
        <span>{cta_primary}</span>
      </a>
      <a href={contact_anchor} class="btn-secondary" id="hero-cta-secondary">
        <Icon name="bx:bxs-paper-plane" class="w-5 h-5" />
        <span>{cta_secondary}</span>
      </a>
    </div>
  </div>
  <div class="hero-scroll-hint" id="hero-scroll-hint" aria-hidden="true">
    <span class="scroll-text-vertical">{scroll_hint}</span>
    <div class="scroll-arrow-long"></div>
  </div>
</section>

<script src="../scripts/sections/hero.ts"></script>

<style>
  @import "../styles/components/HeroSection.css";
</style>
