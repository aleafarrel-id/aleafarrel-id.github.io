---
/**
 * HeroSection.astro
 * Full-screen hero with canvas scroll animation.
 * All text consumed from locale JSON.
 */
import { Icon } from 'astro-icon/components';
interface Props {
  greeting: string;
  name: string;
  title: string;
  subtitle: string;
  cta_primary: string;
  cta_secondary: string;
  scroll_hint: string;
  projects_anchor: string;
  contact_anchor: string;
}

const {
  greeting,
  name,
  title,
  subtitle,
  cta_primary,
  cta_secondary,
  scroll_hint,
  projects_anchor,
  contact_anchor,
} = Astro.props;
---

<section id="hero" aria-label="Hero">
  <div class="hero-content">
    <p class="hero-greeting" id="hero-greeting">{greeting}</p>
    <h1 class="hero-name" id="hero-name">{name}</h1>
    <p class="hero-title" id="hero-title">{title}</p>
    <p class="hero-subtitle" id="hero-subtitle">{subtitle}</p>
    <div class="hero-ctas" id="hero-ctas">
      <a href={projects_anchor} class="btn-primary" id="hero-cta-primary">
        <span>{cta_primary}</span>
      </a>
      <a href={contact_anchor} class="btn-secondary" id="hero-cta-secondary">
        <Icon name="bx:bxs-paper-plane" class="w-5 h-5" />
        <span>{cta_secondary}</span>
      </a>
    </div>
    </div>
  </div>

  <!-- Scroll hint -->
  <div class="hero-scroll-hint" id="hero-scroll-hint" aria-hidden="true">
    <span class="scroll-text-vertical">{scroll_hint}</span>
    <div class="scroll-arrow-long"></div>
  </div>
</section>

<script>
  // Hero entrance animation — runs after preloader hides
  import { gsap } from "gsap";

  function animateHeroIn() {
    const tl = gsap.timeline({ defaults: { ease: "power4.out" } });
    tl.to("#hero-greeting", { opacity: 1, y: 0, duration: 0.7, delay: 0.1 })
      .to("#hero-name", { opacity: 1, y: 0, duration: 0.8 }, "-=0.4")
      .to("#hero-title", { opacity: 1, y: 0, duration: 0.6 }, "-=0.5")
      .to("#hero-subtitle", { opacity: 1, y: 0, duration: 0.6 }, "-=0.4")
      .to("#hero-ctas", { opacity: 1, y: 0, duration: 0.6 }, "-=0.4");
  }

  // Listen for preloader-done event dispatched by canvas script
  document.addEventListener("preloader-done", animateHeroIn, { once: true });
</script>

<style is:global>
  /* ==========================================================
     HERO SECTION
     ========================================================== */

  #hero {
    position: relative;
    z-index: var(--z-base);
    height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: flex-end;
    text-align: left;
    pointer-events: none;
    padding-bottom: var(--space-24);
    padding-left: var(--space-8);
  }

  .hero-content {
    pointer-events: auto;
    padding: var(--space-6);
    max-width: 800px;
  }

  .hero-greeting {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clr-text-secondary);
    margin-bottom: var(--space-5);
    opacity: 0;
    transform: translateY(20px);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .hero-greeting::before {
    content: '';
    display: block;
    width: 40px;
    height: 2px;
    background: var(--clr-accent-blue);
    border-radius: var(--radius-full);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 8vw, var(--text-7xl));
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.05em;
    color: var(--clr-text-primary);
    margin-bottom: var(--space-4);
    width: min-content;
    opacity: 0;
    transform: translateY(30px);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--clr-text-secondary);
    margin-bottom: var(--space-6);
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--clr-text-secondary);
    max-width: 520px;
    margin: 0 0 var(--space-10) 0;
    line-height: 1.7;
    letter-spacing: 0.05em;
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-6);
    justify-content: flex-start;
    flex-wrap: wrap;
    opacity: 0;
    transform: translateY(20px);
  }

  .btn-primary {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-6);
    background: linear-gradient(135deg, var(--clr-accent-blue), var(--clr-accent-blue-light));
    color: var(--clr-bg-deep);
    border-radius: var(--radius-full);
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 20px -2px var(--clr-accent-blue-glow), inset 0 1px 1px color-mix(in srgb, #ffffff 40%, transparent);
    transition: all var(--duration-base) var(--ease-out-expo);
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px 0 var(--clr-accent-blue-glow), inset 0 1px 1px color-mix(in srgb, #ffffff 60%, transparent);
  }

  .btn-primary:active {
    transform: translateY(0px);
    box-shadow: 0 2px 10px -2px var(--clr-accent-blue-glow), inset 0 1px 1px color-mix(in srgb, #ffffff 20%, transparent);
  }

  .btn-secondary {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-6);
    background: color-mix(in srgb, var(--clr-text-primary) 3%, transparent);
    color: var(--clr-text-primary);
    border-radius: var(--radius-full);
    border: 1px solid color-mix(in srgb, var(--clr-text-primary) 10%, transparent);
    cursor: pointer;
    box-shadow: 0 4px 20px -2px color-mix(in srgb, var(--shadow-dark) 50%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: all var(--duration-base) var(--ease-out-expo);
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .btn-secondary:hover {
    transform: translateY(-2px);
    background: color-mix(in srgb, var(--clr-text-primary) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--clr-text-primary) 20%, transparent);
  }

  .btn-secondary:active {
    transform: translateY(0);
    background: color-mix(in srgb, var(--clr-text-primary) 2%, transparent);
  }

  .hero-scroll-hint {
    position: absolute;
    right: var(--space-8);
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    opacity: 0;
    animation: scrollHintFade 2s var(--ease-out-expo) 2s forwards;
    pointer-events: auto;
  }

  .scroll-text-vertical {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--clr-text-secondary);
    writing-mode: vertical-rl;
    text-orientation: sideways;
    transform: rotate(180deg);
    opacity: 0.6;
  }

  .scroll-arrow-long {
    width: 2px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--clr-accent-blue));
    position: relative;
    display: flex;
    justify-content: center;
    animation: scrollLineBounce 2s var(--ease-inout) infinite;
    border-radius: var(--radius-full);
  }

  .scroll-arrow-long::after {
    content: '';
    position: absolute;
    bottom: -2px;
    width: 12px;
    height: 12px;
    border-right: 2px solid var(--clr-accent-blue);
    border-bottom: 2px solid var(--clr-accent-blue);
    transform: rotate(45deg);
    box-shadow: 2px 2px 4px var(--clr-accent-blue-glow);
  }

  @keyframes scrollLineBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(15px); }
  }

  @keyframes scrollHintFade {
    to { opacity: 1; }
  }
</style>
