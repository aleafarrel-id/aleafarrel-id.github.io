---
interface Props {
  phrases?: string[];
}

const { phrases = [] } = Astro.props;
---

<div
  id="preloader"
  data-phrases={JSON.stringify(phrases)}
  class="fixed inset-0 z-[1000] flex flex-col items-center justify-center bg-[var(--clr-bg)] px-6 transition-opacity duration-[1200ms] ease-[cubic-bezier(0.4,0,0.2,1)]"
>
  <div class="w-[85%] sm:w-3/4 max-w-sm flex flex-col gap-3">
    <!-- Text & Percentage Header -->
    <div class="flex justify-between items-end w-full gap-2">
      <div
        class="h-auto overflow-visible relative grid items-center flex-1 min-w-0"
      >
        <span
          id="preloader-phrase"
          class="col-start-1 row-start-1 font-ui text-[10px] sm:text-xs md:text-sm font-medium text-gray-400 tracking-wider md:tracking-widest uppercase leading-tight transition-all duration-300 ease-out"
          style="opacity: 1; filter: blur(0px); transform: translateY(0px);"
        >
          {phrases[0] || "Loading..."}
        </span>
      </div>
      <span
        id="preloader-progress-text"
        class="font-ui text-sm font-bold text-[var(--clr-accent-blue)] tracking-widest"
      >
        0%
      </span>
    </div>

    <!-- Sleek Minimalist Bar -->
    <div
      class="w-full h-[2px] bg-[var(--clr-bg-raised)] rounded-full overflow-hidden relative"
    >
      <div
        id="preloader-progress-bar"
        class="absolute top-0 left-0 h-full bg-[var(--clr-accent-blue)] rounded-full transition-all duration-200 ease-out"
        style="box-shadow: 0 0 12px var(--clr-accent-blue-glow); width: 0%;"
      >
      </div>
    </div>
  </div>
</div>

<script>
  const preloader = document.getElementById("preloader");
  const phraseEl = document.getElementById("preloader-phrase");
  const progressText = document.getElementById("preloader-progress-text");
  const progressBar = document.getElementById("preloader-progress-bar");

  // Prevent scrolling initially
  document.body.style.overflow = "hidden";

  if (typeof window !== "undefined") {
    window.dispatchEvent(new CustomEvent("lenis-stop"));

    let isDone = false;

    window.addEventListener("loader-progress", (e: Event) => {
      if (isDone) return;
      const customEvent = e as CustomEvent;
      const detail = customEvent.detail;

      if (detail && progressText && progressBar) {
        progressText.textContent = `${detail.pct}%`;
        progressBar.style.width = `${detail.pct}%`;

        if (
          detail.phrase &&
          phraseEl &&
          phraseEl.textContent !== detail.phrase
        ) {
          phraseEl.style.opacity = "0";
          phraseEl.style.filter = "blur(4px)";
          phraseEl.style.transform = "translateY(5px)";

          setTimeout(() => {
            if (isDone) return;
            phraseEl.textContent = detail.phrase;
            phraseEl.style.opacity = "1";
            phraseEl.style.filter = "blur(0px)";
            phraseEl.style.transform = "translateY(0px)";
          }, 200);
        }
      }
    });

    window.addEventListener("preloader-done", () => {
      if (isDone) return;
      isDone = true;

      // Force UI to 100% right before fading out so it doesn't look glitched
      if (progressText && progressBar) {
        progressText.textContent = `100%`;
        progressBar.style.width = `100%`;
      }

      setTimeout(() => {
        if (preloader) {
          preloader.style.opacity = "0";
          preloader.style.pointerEvents = "none";
          setTimeout(() => {
            preloader.remove();
          }, 1200);
        }
        document.body.style.overflow = "";
        window.dispatchEvent(new CustomEvent("lenis-start"));
      }, 50);
    });
  }
</script>
