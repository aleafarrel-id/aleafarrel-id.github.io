---
import "../styles/global.css";
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/syne";
import "@fontsource-variable/inter";
import { Icon } from "astro-icon/components";
import { getLocale, getLocaleData, getAlternateUrl } from "../i18n/utils";
import { LoaderOne } from "../components/ui/loader";
import siteConfig from "../siteConfig.json";

interface Props {
  locale?: string;
}

const { locale: rawLocale } = Astro.props;
const locale = getLocale(
  rawLocale ?? (Astro.currentLocale as string | undefined),
);
const data = getLocaleData(locale);
const altUrl = getAlternateUrl(Astro.url.pathname, locale);
const altLang = locale === "en" ? "id" : "en";

// Nav anchors
const base = `/${locale}`;

const instagramUrl =
  siteConfig.socials.find((s) => s.icon === "instagram")?.url || "#";
const githubUrl =
  siteConfig.socials.find((s) => s.icon === "github")?.url || "#";
const emailParts = siteConfig.email.split("@");
const emailUser = emailParts[0];
const emailDomain = emailParts[1] || "";
---

<!doctype html>
<html lang={data.meta.lang}>
  <head>
    <script is:inline>
      (function () {
        var vh = 0;
        var ticking = false;

        function setVH() {
          var vp = window.visualViewport;

          var newVH = (vp ? vp.height : window.innerHeight) * 0.01;
          if (Math.abs(newVH - vh) > 0.1) {
            vh = newVH;
            document.documentElement.style.setProperty("--vh", newVH + "px");
            window.dispatchEvent(new CustomEvent("vh-updated"));
          }
          ticking = false;
        }

        function scheduleVH() {
          if (!ticking) {
            ticking = true;
            window.requestAnimationFrame(setVH);
          }
        }

        if (window.visualViewport) {
          window.visualViewport.addEventListener("resize", scheduleVH, {
            passive: true,
          });
          window.visualViewport.addEventListener("scroll", scheduleVH, {
            passive: true,
          });
        }
        window.addEventListener("resize", scheduleVH, { passive: true });

        setVH();
      })();
    </script>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover"
    />
    <meta name="description" content={data.meta.description} />
    <meta name="author" content="Alea Farrel" />
    <meta property="og:title" content={data.meta.title} />
    <meta property="og:description" content={data.meta.description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#1A1A1A" />

    <link rel="alternate" hreflang={locale} href={Astro.url.href} />
    <link rel="alternate" hreflang={altLang} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href="/en/" />

    <title>{data.meta.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <LoaderOne client:load phrases={data.loading.phrases} />

    <div
      class="mobile-menu"
      id="mobile-menu"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation menu"
    >
      <button
        id="mobile-menu-close"
        aria-label="Close menu"
        style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;cursor:pointer;width:44px;height:44px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--clr-text-primary);"
      >
        <Icon name="bx:bx-x" class="w-8 h-8" aria-hidden="true" />
      </button>
      <nav>
        <ul
          style="list-style:none;display:flex;flex-direction:column;align-items:center;gap:2.5rem;padding:0;"
        >
          <li>
            <a href={`${base}/#about`} class="mobile-nav-link" aria-label={data.nav.about}
              >{data.nav.about}</a
            >
          </li>
          <li>
            <a href={`${base}/#projects`} class="mobile-nav-link" aria-label={data.nav.projects}
              >{data.nav.projects}</a
            >
          </li>
          <li>
            <a href={`${base}/#experience`} class="mobile-nav-link" aria-label={data.nav.experience}
              >{data.nav.experience}</a
            >
          </li>
          <li>
            <a href={`${base}/#gallery`} class="mobile-nav-link" aria-label={data.nav.gallery}
              >{data.nav.gallery}</a
            >
          </li>
          <li>
            <a href={`${base}/#contact`} class="mobile-nav-link" aria-label={data.nav.contact}
              >{data.nav.contact}</a
            >
          </li>
        </ul>
      </nav>
    </div>

    <header id="main-nav" role="banner">
      <a href={`${base}/`} class="nav-logo" aria-label="Alea Farrel — Home">
        AF<span>.</span>
      </a>

      <nav aria-label="Main navigation">
        <ul class="nav-links">
          <li><a href={`${base}/#about`} aria-label={data.nav.about}> {data.nav.about}</a></li>
          <li><a href={`${base}/#projects`} aria-label={data.nav.projects}> {data.nav.projects}</a></li>
          <li><a href={`${base}/#experience`} aria-label={data.nav.experience}> {data.nav.experience}</a></li>
          <li><a href={`${base}/#gallery`} aria-label={data.nav.gallery}> {data.nav.gallery}</a></li>
          <li><a href={`${base}/#contact`} aria-label={data.nav.contact}> {data.nav.contact}</a></li>
        </ul>
      </nav>

      <div style="display:flex;align-items:center;gap:0.75rem;">
        <a
          href={altUrl}
          class="nav-lang-btn"
          aria-label={`Switch to ${altLang === "en" ? "English" : "Indonesian"}`}
        >
          {data.nav.language}
        </a>

        <button
          class="nav-hamburger"
          id="hamburger-btn"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <canvas id="hero-canvas" aria-hidden="true"></canvas>

    <main id="main-content">
      <slot />
    </main>

    <footer id="footer">
      <div class="container">
        <div class="footer-top">
          <div class="footer-brand">
            <a
              href={`${base}/`}
              class="footer-logo"
              aria-label="Alea Farrel — Home"
            >AF<span>.</span></a>
            <p class="footer-description">
              {data.footer.description}
            </p>
          </div>

          <div class="footer-nav">
            <div class="footer-nav-col">
              <span class="footer-nav-title">Menu</span>
              <ul>
                <li><a href={`${base}/#about`}>{data.nav.about}</a></li>
                <li><a href={`${base}/#projects`}>{data.nav.projects}</a></li>
                <li>
                  <a href={`${base}/#experience`}>{data.nav.experience}</a>
                </li>
                <li><a href={`${base}/#gallery`}>{data.nav.gallery}</a></li>
              </ul>
            </div>
            <div class="footer-nav-col">
              <span class="footer-nav-title">Connect</span>
              <ul>
                <li>
                  <a
                    href={instagramUrl}
                    target="_blank"
                    rel="noopener noreferrer">Instagram</a>
                </li>
                <li><button onclick={`window.location.href='mailto:${emailUser}' + '@' + '${emailDomain}'`}>Email</button></li>
                <li>
                  <a href={githubUrl} target="_blank" rel="noopener noreferrer"
                    >GitHub</a>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <div class="footer-copyright">
            <p>
              &copy; {new Date().getFullYear()} Alea Farrel. {
                data.footer.rights
              }
            </p>
            <p class="footer-tech">{data.footer.built_with}</p>
          </div>
        </div>
      </div>

      <button id="back-to-top" class="back-to-top" aria-label="Back to top">
        <Icon name="bx:bx-up-arrow-alt" class="w-6 h-6" aria-hidden="true" />
      </button>
    </footer>

    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      let lenis: any = null;

      const raf = (time: number) => {
        lenis?.raf(time * 1000);
      };

      if (!prefersReducedMotion) {
        gsap.ticker.add(raf);
        gsap.ticker.lagSmoothing(0);
      }

      function initLenis() {
        if (lenis) return;

        lenis = new Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          direction: "vertical",
          gestureDirection: "vertical",
          smooth: true,
          smoothTouch: false,
          touchMultiplier: 2,
          infinite: false,
          autoResize: true,
        } as any);

        // @ts-ignore
        window.lenis = lenis;

        if (!prefersReducedMotion) {
          lenis.on("scroll", ScrollTrigger.update);
        }
      }

      function destroyLenis() {
        if (!lenis) return;
        lenis.destroy();
        lenis = null;
        // @ts-ignore
        window.lenis = null;
      }

      function checkScreenWidthAndInitialize() {
        if (window.matchMedia("(min-width: 768px)").matches) {
          initLenis();
        } else {
          destroyLenis();
        }
      }

      checkScreenWidthAndInitialize();
      window.addEventListener("resize", checkScreenWidthAndInitialize);

      window.addEventListener("lenis-stop", () => lenis?.stop());
      window.addEventListener("lenis-start", () => lenis?.start());

      const nav = document.getElementById("main-nav");
      window.addEventListener(
        "scroll",
        () => {
          nav?.classList.toggle("scrolled", window.scrollY > 60);
        },
        { passive: true },
      );

      const hamburger = document.getElementById("hamburger-btn");
      const mobileMenu = document.getElementById("mobile-menu");
      const closeBtn = document.getElementById("mobile-menu-close");

      function openMenu() {
        mobileMenu?.classList.add("open");
        hamburger?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
        closeBtn?.focus();
      }

      function closeMenu() {
        mobileMenu?.classList.remove("open");
        hamburger?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        hamburger?.focus();
      }

      hamburger?.addEventListener("click", openMenu);
      closeBtn?.addEventListener("click", closeMenu);

      document
        .querySelectorAll(".mobile-nav-link")
        .forEach((link) => link.addEventListener("click", closeMenu));

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeMenu();
      });

      // Smooth scroll for anchor links
      document.querySelectorAll('a[href*="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          const href = anchor.getAttribute('href');
          if (!href) return;
          
          const url = new URL(href, window.location.href);
          if (url.pathname === window.location.pathname) {
            const targetId = url.hash;
            if (targetId && targetId !== '#') {
              const targetEl = document.querySelector(targetId);
              if (targetEl) {
                e.preventDefault();
                if (lenis) {
                  lenis.scrollTo(targetEl, { offset: -80, duration: 1.2 });
                } else {
                  const top = targetEl.getBoundingClientRect().top + window.scrollY - 80;
                  window.scrollTo({ top, behavior: 'smooth' });
                }
              }
            }
          }
        });
      });

      const backToTopBtn = document.getElementById("back-to-top");
      backToTopBtn?.addEventListener("click", () => {
        if (lenis) {
          lenis.scrollTo(0, { duration: 1.2 });
        } else {
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });

      window.addEventListener(
        "scroll",
        () => {
          if (window.scrollY > 300) {
            backToTopBtn?.classList.add("visible");
          } else {
            backToTopBtn?.classList.remove("visible");
          }
        },
        { passive: true },
      );

      const revealObs = new IntersectionObserver(
        (entries) =>
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              revealObs.unobserve(entry.target);
            }
          }),
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => revealObs.observe(el));
    </script>
  </body>
</html>

<style is:global>
  #hero-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: calc(var(--vh, 1dvh) * 100);
    z-index: var(--z-canvas);
    pointer-events: none;
    object-fit: cover;
  }

  #main-nav {
    position: fixed;
    top: var(--space-4);
    left: var(--space-4);
    right: var(--space-4);
    max-width: 1200px;
    margin: 0 auto;
    z-index: var(--z-sticky);
    padding: var(--space-4) var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition-property: background, backdrop-filter, box-shadow, padding, top;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
    border-radius: var(--radius-full);
  }

  #main-nav.scrolled {
    background: color-mix(in srgb, var(--clr-bg-deep) 80%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 8px 32px var(--shadow-dark),
      inset 0 1px 0 var(--shadow-light);
    padding: var(--space-3) var(--space-6);
    top: var(--space-2);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--clr-text-primary);
    letter-spacing: -0.02em;
  }

  .nav-logo span {
    color: var(--clr-accent-blue);
  }

  .nav-links {
    display: none;
    gap: var(--space-8);
    list-style: none;
  }

  .nav-links a {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--clr-text-secondary);
    transition: color var(--duration-fast) ease;
    position: relative;
    padding: var(--space-2) var(--space-3);
    margin: calc(var(--space-2) * -1) calc(var(--space-3) * -1);
    border-radius: var(--radius-sm);
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: var(--space-3);
    width: 0;
    height: 2px;
    background: var(--clr-accent-blue);
    border-radius: var(--radius-full);
    transition: width var(--duration-base) var(--ease-out-expo);
  }
  @media (hover: hover) {
    .nav-links a:hover {
      color: var(--clr-text-primary);
    }

    .nav-links a:hover::after {
      width: calc(100% - calc(var(--space-3) * 2));
    }
  }

  .nav-lang-btn {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: 600;
    padding: 2px 0 0 2px; /* Optical adjustment */
    height: 40px;
    width: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    line-height: 1;
    text-decoration: none;
    background: var(--clr-bg);
    box-shadow: var(--neu-raised-sm);
    border-radius: var(--radius-full);
    color: var(--clr-text-secondary);
    border: none;
    cursor: pointer;
    touch-action: manipulation;
    transition-property: color, box-shadow, transform;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
  }
  @media (hover: hover) {
    .nav-lang-btn:hover {
      color: var(--clr-accent-blue);
      box-shadow: var(--neu-raised);
    }
  }

  #footer {
    position: relative;
    z-index: var(--z-base);
    background: var(--clr-bg);
    padding: var(--space-16) 0 var(--space-12) 0;
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    margin-bottom: var(--space-16);
    align-items: flex-start;
    text-align: left;
  }

  @media (min-width: 640px) {
    .footer-top {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (min-width: 1024px) {
    .footer-top {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 100%;
    align-items: flex-start;
  }

  @media (min-width: 1024px) {
    .footer-brand {
      max-width: 300px;
    }
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--clr-text-primary);
    letter-spacing: -0.02em;
    display: inline-block;
  }

  .footer-logo span {
    color: var(--clr-accent-blue);
  }

  .footer-description {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--clr-text-secondary);
    line-height: 1.6;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    width: 100%;
  }

  @media (min-width: 480px) {
    .footer-nav {
      gap: var(--space-16);
    }
  }

  @media (min-width: 768px) {
    .footer-nav {
      display: flex;
      justify-content: flex-end;
      gap: var(--space-24);
    }
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .footer-nav-title {
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--clr-text-primary);
  }

  .footer-nav-col ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-nav-col a,
  .footer-nav-col button {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--clr-text-secondary);
    transition: color var(--duration-fast) ease;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
  }

  @media (hover: hover) {
    .footer-nav-col a:hover,
    .footer-nav-col button:hover {
      color: var(--clr-accent-blue);
    }
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    align-items: flex-start;
    text-align: left;
    border-top: 1px solid
      color-mix(in srgb, var(--clr-text-primary) 10%, transparent);
    padding-top: var(--space-8);
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .footer-copyright {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: flex-start;
  }

  .footer-copyright p {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--clr-text-muted);
  }

  .footer-tech {
    font-size: var(--text-xs) !important;
    opacity: 0.7;
  }

  .back-to-top {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: var(--z-sticky);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: color-mix(in srgb, var(--clr-bg-deep) 80%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid
      color-mix(in srgb, var(--clr-text-primary) 10%, transparent);
    color: var(--clr-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 12px var(--shadow-dark);
    transition: all var(--duration-base) var(--ease-out-expo);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
  }

  .back-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (hover: hover) {
    .back-to-top:hover {
      color: var(--clr-accent-blue);
      border-color: var(--clr-accent-blue);
      transform: translateY(-4px) scale(1.05);
      background: var(--clr-bg-deep);
    }
  }

  .nav-hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    min-width: 44px;
    min-height: 44px;
    justify-content: center;
    align-items: center;
    touch-action: manipulation;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--clr-text-primary);
    border-radius: 2px;
    transition-property: transform, opacity, background-color;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-sticky) + 1);
    background: var(--clr-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    padding: var(--space-8);
    text-align: center;
    opacity: 0;
    visibility: hidden;
    transition-property: opacity, visibility;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu a {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 8vw, 2.5rem);
    font-weight: 800;
    color: var(--clr-text-primary);
    letter-spacing: -0.02em;
    transition: color var(--duration-fast) ease;
  }
  @media (hover: hover) {
    .mobile-menu a:hover {
      color: var(--clr-accent-blue);
    }
  }

  @media (max-width: 767px) {
    #main-nav {
      top: var(--space-2);
      left: var(--space-2);
      right: var(--space-2);
      padding: var(--space-2) var(--space-3);
    }
    .nav-logo {
      font-size: var(--text-lg);
    }
    .nav-lang-btn {
      height: 36px;
      width: 36px;
      padding: 2px 0 0 2px;
      font-size: var(--text-sm);
