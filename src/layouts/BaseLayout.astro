---
/**
 * BaseLayout.astro — Root HTML shell
 * Consumed by [lang]/index.astro — locale passed as prop.
 */
import "../styles/global.css";
import "@fontsource-variable/space-grotesk";
import "@fontsource-variable/syne";
import "@fontsource-variable/inter";
import { Icon } from "astro-icon/components";
import { getLocale, getLocaleData, getAlternateUrl } from "../i18n/utils";
import { LoaderOne } from "../components/ui/loader";

interface Props {
  locale?: string;
}

const { locale: rawLocale } = Astro.props;
const locale = getLocale(
  rawLocale ?? (Astro.currentLocale as string | undefined),
);
const data = getLocaleData(locale);
const altUrl = getAlternateUrl(Astro.url.pathname, locale);
const altLang = locale === "en" ? "id" : "en";

// Nav anchors
const base = `/${locale}`;
---

<!doctype html>
<html lang={data.meta.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={data.meta.description} />
    <meta name="author" content="Alea Farrel" />
    <meta property="og:title" content={data.meta.title} />
    <meta property="og:description" content={data.meta.description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#1A1A1A" />

    <!-- i18n alternate links -->
    <link rel="alternate" hreflang={locale} href={Astro.url.href} />
    <link rel="alternate" hreflang={altLang} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href="/en/" />

    <!-- Offline Fonts via Fontsource -->

    <title>{data.meta.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <!-- ══ PRELOADER ══════════════════════════════════════════ -->
    <LoaderOne client:load phrases={data.loading.phrases} />

    <!-- ══ MOBILE MENU ════════════════════════════════════════ -->
    <div
      class="mobile-menu"
      id="mobile-menu"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation menu"
    >
      <button
        id="mobile-menu-close"
        aria-label="Close menu"
        style="position:absolute;top:1.5rem;right:1.5rem;background:none;border:none;cursor:pointer;width:44px;height:44px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--clr-text-primary);"
      >
        <Icon name="bx:bx-x" class="w-8 h-8" />
      </button>
      <nav>
        <ul
          style="list-style:none;display:flex;flex-direction:column;align-items:center;gap:2.5rem;padding:0;"
        >
          <li>
            <a href={`${base}/#about`} class="mobile-nav-link"
              >{data.nav.about}</a>
          </li>
          <li>
            <a href={`${base}/#projects`} class="mobile-nav-link"
              >{data.nav.projects}</a>
          </li>
          <li>
            <a href={`${base}/#experience`} class="mobile-nav-link"
              >{data.nav.experience}</a>
          </li>
          <li>
            <a href={`${base}/#gallery`} class="mobile-nav-link"
              >{data.nav.gallery}</a>
          </li>
          <li>
            <a href={`${base}/#contact`} class="mobile-nav-link"
              >{data.nav.contact}</a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- ══ NAVIGATION ════════════════════════════════════════ -->
    <header id="main-nav" role="banner">
      <a href={`${base}/`} class="nav-logo" aria-label="Alea Farrel — Home">
        AF<span>.</span>
      </a>

      <nav aria-label="Main navigation">
        <ul class="nav-links">
          <li><a href={`${base}/#about`}> {data.nav.about}</a></li>
          <li><a href={`${base}/#projects`}> {data.nav.projects}</a></li>
          <li><a href={`${base}/#experience`}> {data.nav.experience}</a></li>
          <li><a href={`${base}/#gallery`}> {data.nav.gallery}</a></li>
          <li><a href={`${base}/#contact`}> {data.nav.contact}</a></li>
        </ul>
      </nav>

      <div style="display:flex;align-items:center;gap:0.75rem;">
        <!-- Language toggle -->
        <a
          href={altUrl}
          class="nav-lang-btn"
          aria-label={`Switch to ${altLang === "en" ? "English" : "Indonesian"}`}
        >
          {data.nav.language}
        </a>

        <!-- Hamburger -->
        <button
          class="nav-hamburger"
          id="hamburger-btn"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <!-- ══ CANVAS (fixed, full-screen background) ════════════ -->
    <canvas id="hero-canvas" aria-hidden="true"></canvas>

    <!-- ══ PAGE CONTENT ══════════════════════════════════════ -->
    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <!-- ══ FOOTER ════════════════════════════════════════════ -->
    <footer id="footer">
      <div class="container">
        <div class="footer-inner">
          <p class="footer-text">
            &copy; {new Date().getFullYear()} Alea Farrel. {data.footer.rights}
          </p>
          <div class="footer-logo">AF<span>.</span></div>
        </div>
      </div>
    </footer>

    <!-- ══ INLINE SCRIPTS ════════════════════════════════════ -->
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      // ── Respect Reduced Motion ──────────────────────────────
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // ── Smooth Scroll (Lenis + GSAP) ───────────────────────
      const lenis = new Lenis();
      
      if (!prefersReducedMotion) {
        lenis.on("scroll", ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);
      }

      // ── Scroll nav ────────────────────────────────────────
      const nav = document.getElementById("main-nav");
      window.addEventListener(
        "scroll",
        () => {
          nav?.classList.toggle("scrolled", window.scrollY > 60);
        },
        { passive: true },
      );

      // ── Mobile menu ───────────────────────────────────────
      const hamburger = document.getElementById("hamburger-btn");
      const mobileMenu = document.getElementById("mobile-menu");
      const closeBtn = document.getElementById("mobile-menu-close");

      function openMenu() {
        mobileMenu?.classList.add("open");
        hamburger?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
        closeBtn?.focus();
      }

      function closeMenu() {
        mobileMenu?.classList.remove("open");
        hamburger?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        hamburger?.focus();
      }

      hamburger?.addEventListener("click", openMenu);
      closeBtn?.addEventListener("click", closeMenu);

      // Close when clicking a nav link
      document
        .querySelectorAll(".mobile-nav-link")
        .forEach((link) => link.addEventListener("click", closeMenu));

      // Close on Escape
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeMenu();
      });

      // ── Scroll reveal ─────────────────────────────────────
      const revealObs = new IntersectionObserver(
        (entries) =>
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              revealObs.unobserve(entry.target);
            }
          }),
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => revealObs.observe(el));
    </script>
  </body>
</html>

<style is:global>
  /* ---------- Canvas Background ---------- */

  #hero-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: var(--z-canvas);
    pointer-events: none;
    object-fit: cover;
  }

  /* ---------- Navigation ---------- */

  #main-nav {
    position: fixed;
    top: var(--space-4);
    left: var(--space-4);
    right: var(--space-4);
    max-width: 1200px;
    margin: 0 auto;
    z-index: var(--z-sticky);
    padding: var(--space-4) var(--space-6);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition-property: background, backdrop-filter, box-shadow, padding, top;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
    border-radius: var(--radius-full);
  }

  #main-nav.scrolled {
    background: color-mix(in srgb, var(--clr-bg-deep) 80%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow:
      0 8px 32px var(--shadow-dark),
      inset 0 1px 0 var(--shadow-light);
    padding: var(--space-3) var(--space-6);
    top: var(--space-2);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--clr-text-primary);
    letter-spacing: -0.02em;
  }

  .nav-logo span {
    color: var(--clr-accent-blue);
  }

  .nav-links {
    display: none;
    gap: var(--space-8);
    list-style: none;
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-links a {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--clr-text-secondary);
    transition: color var(--duration-fast) ease;
    position: relative;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--clr-accent-blue);
    border-radius: var(--radius-full);
    transition: width var(--duration-base) var(--ease-out-expo);
  }

  .nav-links a:hover {
    color: var(--clr-text-primary);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-lang-btn {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-2) var(--space-4);
    background: var(--clr-bg);
    box-shadow: var(--neu-raised-sm);
    border-radius: var(--radius-full);
    color: var(--clr-text-secondary);
    border: none;
    cursor: pointer;
    transition-property: color, box-shadow, transform;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
  }

  .nav-lang-btn:hover {
    color: var(--clr-accent-blue);
    box-shadow: var(--neu-raised);
  }

  /* ==========================================================
   FOOTER
   ========================================================== */

  #footer {
    position: relative;
    z-index: var(--z-base);
    background: var(--clr-bg);
    padding: var(--space-8) 0;
    border-top: 1px solid
      color-mix(in srgb, var(--clr-text-primary) 10%, transparent);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-text {
    font-family: var(--font-ui);
    font-size: var(--text-sm);
    color: var(--clr-text-muted);
  }

  .footer-heart {
    color: var(--clr-accent-orange);
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--clr-text-primary);
    letter-spacing: -0.02em;
  }

  .footer-logo span {
    color: var(--clr-accent-blue);
  }

  /* ==========================================================
   MOBILE MENU
   ========================================================== */

  .nav-hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    min-width: 44px;
    min-height: 44px;
    justify-content: center;
    align-items: center;
  }

  @media (min-width: 768px) {
    .nav-hamburger {
      display: none;
    }
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--clr-text-primary);
    border-radius: 2px;
    transition-property: transform, opacity, background-color;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-sticky) + 1);
    background: color-mix(in srgb, var(--clr-bg) 98%, transparent);
    backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    opacity: 0;
    visibility: hidden;
    transition-property: opacity, visibility;
    transition-duration: var(--duration-base);
    transition-timing-function: var(--ease-out-expo);
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu a {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 800;
    color: var(--clr-text-primary);
    letter-spacing: -0.02em;
    transition: color var(--duration-fast) ease;
  }

  .mobile-menu a:hover {
    color: var(--clr-accent-blue);
  }
</style>
